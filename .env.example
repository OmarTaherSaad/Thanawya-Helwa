APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=laravel
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_DRIVER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=mt1

MIX_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
MIX_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# Scout (search): database | collection | meilisearch | null
SCOUT_DRIVER=database
SCOUT_PREFIX=
SCOUT_QUEUE=false

MEILISEARCH_HOST=http://127.0.0.1:7700
MEILISEARCH_KEY=

# Site-wide AdSense (non-home layout). Needs numeric unit IDs from AdSense.
ADS_ENABLED=false
ADSENSE_CLIENT=
ADSENSE_SLOT_SIDEBAR_TOP=
ADSENSE_SLOT_IN_CONTENT=
ADSENSE_SLOT_FOOTER=
# Legacy names (optional fallback for slots)
ADS_SLOT_SIDEBAR_TOP=
ADS_SLOT_IN_CONTENT=
ADS_SLOT_FOOTER=

# Page speed middleware (optional)
LARAVEL_PAGE_SPEED_ENABLE=true

# SEO / social previews (optional; absolute URL recommended for OG image)
SEO_DEFAULT_OG_IMAGE=
SEO_TWITTER_SITE=

# tansik.digital.gov.eg coordination importer (optional; defaults 120s / 60s connect)
# TANSIK_DIGITAL_GOV_IMPORT_HTTP_TIMEOUT=120
# TANSIK_DIGITAL_GOV_IMPORT_HTTP_CONNECT_TIMEOUT=60
# Prefer IPv4 (helps when IPv6 route to the ministry host is blackholed)
# TANSIK_DIGITAL_GOV_IMPORT_FORCE_IPV4=true
# Outbound HTTP proxy for this importer only (e.g. http://127.0.0.1:8888)
# TANSIK_DIGITAL_GOV_IMPORT_HTTP_PROXY=
# Directory of Limit*.htm from `php artisan tansik:pull-government-coordination-limits …` (offline import on blocked hosts)
# TANSIK_DIGITAL_GOV_IMPORT_LIMITS_DIR=
