# =============================================================================
# Thanawya Helwa — production .env template
# Copy to server `.env`, replace CHANGE_ME / generate secrets, then:
#   php artisan key:generate --show   # only if APP_KEY empty
#   php artisan config:cache
# =============================================================================

APP_NAME="Thanawya Helwa"
APP_ENV=production
APP_KEY=base64:CHANGE_ME_run_php_artisan_key_generate
APP_DEBUG=false
APP_URL=https://www.thanawyahelwa.org
# Must match your public canonical host (www or apex). Non-matching hosts get a 301 to APP_URL when SEO_CANONICAL_HOST_REDIRECT is true.
# ASSET_URL=https://www.thanawyahelwa.org

LOG_CHANNEL=daily
LOG_LEVEL=warning

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=CHANGE_ME
DB_USERNAME=CHANGE_ME
DB_PASSWORD=CHANGE_ME

BROADCAST_DRIVER=log
CACHE_DRIVER=file
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120
# SESSION_DOMAIN=   # optional; leave unset for apex-only cookies
SESSION_SECURE_COOKIE=true

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

FILESYSTEM_DISK=public

MAIL_MAILER=smtp
MAIL_HOST=CHANGE_ME
MAIL_PORT=587
MAIL_USERNAME=CHANGE_ME
MAIL_PASSWORD=CHANGE_ME
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@thanawyahelwa.org
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=mt1

MIX_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
MIX_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# --- App-specific ---
GOOGLE_RECAPTCHA_KEY=
GOOGLE_RECAPTCHA_SECRET=
APP_DEPLOY_SECRET=

FACEBOOK_KEY=
FACEBOOK_SECRET=
FACEBOOK_REDIRECT_URI="${APP_URL}/callback/facebook"

# Scout: database | meilisearch | null
SCOUT_DRIVER=database
SCOUT_PREFIX=thanawyahelwa
SCOUT_QUEUE=false

MEILISEARCH_HOST=http://127.0.0.1:7700
MEILISEARCH_KEY=

# Telescope: disable on public production unless protected
TELESCOPE_ENABLED=false

# Page speed middleware
LARAVEL_PAGE_SPEED_ENABLE=true

# --- AdSense (single display unit; non-home layout) ---
ADS_ENABLED=true
ADSENSE_CLIENT=ca-pub-CHANGE_ME
ADSENSE_SLOT=
ADS_MIN_HEIGHT=120px
ADS_PUSH_IDLE_MS=800

# --- SEO / social / JSON-LD ---
SEO_DEFAULT_OG_IMAGE=https://www.thanawyahelwa.org/storage/CHANGE_ME/og-default.jpg
SEO_TWITTER_SITE=
SEO_SITE_NAME=
SEO_ORGANIZATION_LOGO=https://www.thanawyahelwa.org/storage/CHANGE_ME/logo.png
SEO_OG_LOCALE=ar_EG
# 301 redirect to APP_URL when Host differs (www vs apex). Set false only for unusual multi-host dev setups.
SEO_CANONICAL_HOST_REDIRECT=true

# --- Tansik digital.gov.eg importer (optional) ---
# TANSIK_DIGITAL_GOV_IMPORT_HTTP_TIMEOUT=120
# TANSIK_DIGITAL_GOV_IMPORT_HTTP_CONNECT_TIMEOUT=60
# TANSIK_DIGITAL_GOV_IMPORT_FORCE_IPV4=true
# TANSIK_DIGITAL_GOV_IMPORT_HTTP_PROXY=
# TANSIK_DIGITAL_GOV_IMPORT_LIMITS_DIR=
